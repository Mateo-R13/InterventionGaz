      -
        internal_properties : 
        code : |1+
         // sélection d'une image dans la galerie
         sCheminImage est une chaine=AlbumSélecteur(albumImage)
         
         si sCheminImage<>"" ALORS
         	{IMG_Image..LiaisonFichier,indRubrique}=fChargeBuffer(sCheminImage)
         	IMG_Image={IMG_Image..LiaisonFichier,indRubrique}
         
         	SI pas EnModeSimulateur() ALORS
         		fSupprime(sCheminImage)
         	fin
         FIN
        type : 18
      -
        type : 161
        enabled : false
