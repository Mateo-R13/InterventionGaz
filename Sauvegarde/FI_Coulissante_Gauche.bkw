               		<§rad:1§>
               	// a propos de l'application<§rad:1§>
               	CAS 3<§rad:1§>
               		// A FAIRE : A propos : Indiquer ici l'url d'une page sur votre application<§rad:1§>
               		sURL = "http://..."<§rad:1§>
               		<§rad:1§>
               		// Ouverture du lien<§rad:1§>
               		LanceAppliAssociée(sURL)<§rad:1§>
               		<§rad:1§>
               	// Autres apps<§rad:1§>
               	CAS 4<§rad:1§>
               		<§rad:1§>
               		<COMPILE SI TypeConfiguration=Android><§rad:1§>
               			// Voir sur http://developer.android.com/distribute/tools/promote/linking.html<§rad:1§>
               			// Par exemple, le lien vers les produits développés par PCSOFT - WINDEV est :<§rad:1§>
               			// sURL = "market://search?q=pub:PC+SOFT+-+WINDEV"<§rad:1§>
               			// A FAIRE : A propos : Renseigner l'url de recherche des applications de la même société<§rad:1§>
               			sURL = "market://search?q=pub:..."<§rad:1§>
               		<fin><§rad:1§>
               		<COMPILE SI TypeConfiguration=iOS><§rad:1§>
               			// Exemple d'URL pour l'Apple Store :<§rad:1§>
               			// sURL = "https://apps.apple.com/fr/developer/pc-soft/id466497592"<§rad:1§>
               			// A FAIRE : A propos : Renseigner l'url de recherche des applications de la même société<§rad:1§>
               			sURL = "https://apps.apple.com/fr/developer/..."<§rad:1§>
               		<FIN><§rad:1§>
               		// Ouverture du lien<§rad:1§>
               		si sURL<>"" alors<§rad:1§>
               			LanceAppliAssociée(sURL)	<§rad:1§>
               		FIN<§rad:1§>
               		<§rad:1§>
               FIN<§rad:1§>
               <§rad:1§>
               <§rad:1§>
