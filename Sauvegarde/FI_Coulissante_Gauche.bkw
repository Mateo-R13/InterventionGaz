               <§rad:1§>
               sURL est une chaine ansi<§rad:1§>
               <§rad:1§>
               SELON ZM_MENU<§rad:1§>
               	// Version<§rad:1§>
               	CAS 1<§rad:1§>
               		// Pas d'actions particulières<§rad:1§>
               		<§rad:1§>
               	// Noter<§rad:1§>
               	CAS 2<§rad:1§>
               		<COMPILE SI TypeConfiguration=Android><§rad:1§>
               			AppliOuvreFiche()<§rad:1§>
               		<SINON><§rad:1§>
