  p_codes :
   -
     internal_properties : IQAAACAAAACkPd4ZUggsb0dQYlzxzLQPVTOl+iSdLur5WQ2zxxwEP9sCZ/UEjyk3L+iukJ8OpyAFt1qumHf2tKmFK+2IfMvFMdK5lbPaao7JoJ+q6trSQ6ML8x20JiNkRxtRTb341zNFWMsbNZ8nq17G
     code : |1-
      procédure MaFenêtre(mode_ajout est un booléen)
      COMBO_Statut.Ajoute("Non traité")
      COMBO_Statut.Ajoute("En cours")
      COMBO_Statut.Ajoute("Terminé")
      COMBO_Statut									= "Non traité"
      
      FI_Coulissante_Menu_Image.procedure_modif_image	= onModifImage
      
      SI mode_ajout ALORS
      	HRAZ()
      SINON
      	FichierVersEcran()
      FIN
      
      MaFenêtre..ValeurRenvoyée = Faux
      
      // Chargement des clients dans la combo
      Client.LitPremier()
      TANTQUE PAS Client.EnDehors()
      	COMBO_Client.Ajoute(Client.nom)
      	Client.LitSuivant()
      FIN
   -
     internal_properties : IQAAACAAAADkhoSsmgm6IVaFN+6K3K3YRw5S+T0eydHvOhj+LAVc9pG7t6AZRXVmLV8fg0wRXG6jmatrgAjtMZZ+GgcnPg3+41gcRfDv59FmPGOmEXAAogckwmnrEZqlgWHwcYlN+2EN4g3Nr9/aE0hhg5wC1Tvhi5olz+PvsE/bS0G0ybpCEIH6R7YMWN8=
     code : |1-
      // callback de modification d'image
      FI_Coulissante_Menu_Image.procedure_modif_image = onModifImage<§rad:1§>
      <§rad:1§>
      // ajout<§rad:1§>
      si mode_ajout alors<§rad:1§>
      	HRAZ()<§rad:1§>
      <§rad:1§>
      // modification<§rad:1§>
      SINON<§rad:1§>
      	FichierVersEcran()<§rad:1§>
      fin<§rad:1§>
      <§rad:1§>
      // par défaut<§rad:1§>
      mafenêtre..ValeurRenvoyée = faux
      
      // Chargement des clients dans la combo
      Client.LitPremier(Nom)
      TANTQUE PAS Client.EnDehors()
      	COMBO_Client.Ajoute(Client.idClient + TAB + Client.Nom)
      	Client.LitSuivant(Nom)
      FIN
      <§rad:1§>
