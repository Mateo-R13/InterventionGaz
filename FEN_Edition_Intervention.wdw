         <§rad:1§>
        type : 14
      -
        internal_properties : IQAAACAAAADdm4HbBhL3Bt2sEibGKKZZiVCdxLexEcW+PkV2Kl2sP4k49Fc/B9MpiJ6JWzm8BcSpkG99rW4Uk55/U77otSxyuZrrVP+nagd0WDOxNhV94jPXJzqWZzWHeNnnDvSuUaBM4/3VOQn+/0ikTA==
        code : |1-
         SI SAI_Heure = "" ALORS
         	Info("Veuillez saisir une description.")
         	RETOUR
         FIN
         
         // Récupération du client
         HLitRecherchePremier(Client, nom, COMBO_Client)
         Intervention.IdClient = Client.idClient
         
         ÉcranVersFichier()
         Intervention.statut = COMBO_Statut
         
         SI mode_ajout ALORS
         	Intervention.Ajoute()
         SINON
         	Intervention.Modifie()
         FIN
         
         SI ErreurDétectée ALORS
         	Erreur(ErreurInfo(errRésumé))
         	RETOUR
         FIN
         
         Info("Intervention enregistrée avec succès !")
         MaFenêtre..ValeurRenvoyée = Vrai
         Ferme()
        type : 18
      -
