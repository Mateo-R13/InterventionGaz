      -
        code : |1-
         
         // Variable locale
         PhotoProduit est une chaîne
         
         // On lance l'appareil photo
         PhotoProduit = VidéoLanceAppli(viCaptureImage)
         
         SI PhotoProduit <> "" ALORS
         	IMG_Photo = PhotoProduit
         fin
